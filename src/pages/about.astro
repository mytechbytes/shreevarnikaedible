---
import Base from "../layouts/Base.astro";
import site from "../data/site.json";
const a = site.about;
---
<Base
  title="About Us — Shree Varnika Edible"
  description="Founded in 2010 by Mr. Tara Shankar Singh — pioneering purity through KV Automation, manufacturing 100% vegetarian edible gold & silver leaves."
  activeId="about"
>
  <!-- HERO -->
  <section class="section">
    <div class="wrap">
      <div class="grid lg:grid-cols-2 gap-10 items-center">
        <div class="reveal">
          <p class="eyebrow mb-4"><span class="kicker-line"></span>&nbsp; {a.hero.eyebrow}</p>
          <h1 style="font-size:clamp(2.6rem,8vw,4.2rem)">{a.hero.title}</h1>
          <p class="muted" style="font-size:1.06rem;max-width:48ch;margin-top:1.2rem">{a.hero.body}</p>
          <div style="display:flex;gap:12px;margin-top:1.8rem;flex-wrap:wrap">
            <a class="btn btn-primary" href="/products.html">Our Products</a>
            <a class="btn btn-outline" href="/contact.html">Contact Us</a>
          </div>
        </div>
        <div class="reveal shadow-soft" style="border-radius:24px;overflow:hidden;aspect-ratio:4/5;background:var(--brand-50)">
          <img class="hero-img" src={a.hero.image} alt="Mr. Tara Shankar Singh" />
        </div>
      </div>
    </div>
  </section>

  <!-- HERITAGE -->
  <section class="band-brand">
    <div class="wrap section">
      <div class="grid lg:grid-cols-2 gap-10 items-start">
        <div class="reveal">
          <p class="eyebrow mb-3">{a.heritage.eyebrow}</p>
          <h2 style="font-size:clamp(2rem,6vw,3rem)">{a.heritage.title}</h2>
        </div>
        <div class="reveal">
          {a.heritage.paragraphs.map((p, i) => (
            <p class="muted" style={i > 0 ? "margin-top:1rem" : ""}>{p}</p>
          ))}
          <div style="display:flex;gap:30px;margin-top:1.6rem">
            <div><div class="stat-num" data-count="13" data-suffix="+">13+</div><p class="muted" style="font-size:.85rem">Years of experience</p></div>
            <div><div class="stat-num" data-count="100" data-suffix="%">100%</div><p class="muted" style="font-size:.85rem">Vegetarian certified</p></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRODUCT EXCELLENCE -->
  <section class="section">
    <div class="wrap">
      <div class="reveal" style="text-align:center;max-width:46ch;margin:0 auto 38px">
        <p class="eyebrow mb-2">Product Excellence</p>
        <h2 style="font-size:clamp(2rem,6vw,2.8rem)">Crafted for the connoisseur</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {a.excellence.map((e) => (
          <div class="card reveal" style="padding:26px">
            <h3 class="serif" style="font-size:1.3rem;margin-bottom:.5rem">{e.title}</h3>
            <p class="muted" style="font-size:.94rem">{e.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FACTSHEET -->
  <section class="band-dark">
    <div class="wrap section">
      <p class="eyebrow mb-3">Corporate Factsheet</p>
      <h2 style="color:#fff;font-size:clamp(1.9rem,5.5vw,2.6rem);margin-bottom:30px">A snapshot of our operational identity</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-y-8 gap-x-6">
        {a.factsheet.map((f) => (
          <div>
            <div style="color:var(--brand-300);font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;font-weight:700">{f.label}</div>
            <div class="serif" style="color:#fff;font-size:1.25rem;margin-top:.2rem">{f.value}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LEADERSHIP -->
  <section class="section">
    <div class="wrap">
      <div style="text-align:center;margin-bottom:36px">
        <p class="eyebrow mb-2">Our People</p>
        <h2 style="font-size:clamp(2rem,6vw,2.8rem)">Meet our leadership</h2>
      </div>
      <div class="grid sm:grid-cols-3 gap-6" style="max-width:820px;margin:0 auto">
        {a.leadership.map((l) => (
          <div class="card reveal" style="padding:22px;text-align:center">
            {l.image ? (
              <div style="width:104px;height:104px;border-radius:50%;overflow:hidden;margin:0 auto 14px;background:var(--brand-50)"><img src={l.image} alt={l.name} style="width:100%;height:100%;object-fit:cover" /></div>
            ) : (
              <div style="width:104px;height:104px;border-radius:50%;overflow:hidden;margin:0 auto 14px;background:var(--brand-100);display:grid;place-items:center;color:var(--brand-600);font-family:'Marcellus',serif;font-size:2rem">{l.initials}</div>
            )}
            <h3 class="serif" style="font-size:1.2rem">{l.name}</h3>
            <p style="color:var(--brand-700);font-size:.82rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase">{l.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="padding-top:0">
    <div class="wrap">
      <div class="band-brand shadow-soft" style="border-radius:24px;padding:clamp(28px,6vw,56px);text-align:center">
        <h2 style="font-size:clamp(1.9rem,5.5vw,2.8rem);max-width:22ch;margin:0 auto">Luxury and elegance, accessible to everyone</h2>
        <div style="display:flex;gap:12px;justify-content:center;margin-top:1.6rem;flex-wrap:wrap">
          <a class="btn btn-primary" href="/products.html">Explore Products</a>
          <a class="btn btn-outline" href="/contact.html">Get in Touch</a>
        </div>
      </div>
    </div>
  </section>
</Base>
