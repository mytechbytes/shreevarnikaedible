---
import Base from "../layouts/Base.astro";
import ProductCard from "../components/ProductCard.astro";
import itemsData from "../data/items.json";
import site from "../data/site.json";
const items = itemsData;
const featured = items.slice(0, 6);
const ig = site.instagram.images;
const tiles = [
  { id: "food", label: "Food Products", more: "Saffron, Hing & more", img: "/assets/images/hing.jpg" },
  { id: "pooja", label: "Pooja Articles", more: "Silver & gold coated", img: "/assets/images/pooja.jpg" },
  { id: "leaves", label: "Silver & Gold Leaves", more: "Edible vark", img: "/assets/images/gold-leaves.jpg" },
];
---
<Base activeId="home" canonical={site.seo.url + "/"}>
  <!-- HERO -->
  <section class="section" style="padding-top:clamp(28px,5vw,52px)">
    <div class="wrap">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <div class="reveal">
          <p class="eyebrow mb-4"><span class="kicker-line"></span>&nbsp; Royal Craftsmanship, Pure Ingredients</p>
          <h1 style="font-size:clamp(2.6rem,8vw,4.4rem)">A touch of luxury<br>for your home.</h1>
          <p class="muted" style="font-size:1.06rem;max-width:46ch;margin-top:1.2rem">
            Shree Varnika offers a refined range of edible silver &amp; gold leaves, premium saffron and hing,
            coated dry fruits, sweets and pooja articles — crafted with automated precision and timeless tradition.
          </p>
          <div style="display:flex;flex-wrap:wrap;gap:12px;margin-top:1.8rem">
            <a class="btn btn-primary" href="/products.html">Explore Our Products</a>
            <a class="btn btn-outline" href="/about.html">Our Story</a>
          </div>
          <div style="display:flex;flex-wrap:wrap;gap:22px;margin-top:2.2rem">
            <div><div class="serif" style="font-size:1.6rem;color:var(--brand-700)">13+</div><div class="muted" style="font-size:.82rem">Years of expertise</div></div>
            <div style="width:1px;background:var(--line)"></div>
            <div><div class="serif" style="font-size:1.6rem;color:var(--brand-700)">100%</div><div class="muted" style="font-size:.82rem">Vegetarian certified</div></div>
            <div style="width:1px;background:var(--line)"></div>
            <div><div class="serif" style="font-size:1.6rem;color:var(--brand-700)">KV</div><div class="muted" style="font-size:.82rem">Automation, touch-free</div></div>
          </div>
        </div>

        <div class="reveal" style="position:relative">
          <div class="shadow-soft" style="border-radius:24px;overflow:hidden;aspect-ratio:4/3;background:var(--brand-50)">
            <img class="hero-img" src="/assets/images/dryfruits.png" alt="Gold and silver coated dry fruits" width="1400" height="1050" />
          </div>
          <div class="shadow-soft" style="position:absolute;left:-6px;bottom:-18px;background:var(--surface);border:1px solid var(--line);border-radius:16px;padding:14px 16px;display:flex;gap:12px;align-items:center;max-width:230px">
            <img src="/assets/images/saffron.png" alt="Saffron" style="width:48px;height:48px;border-radius:10px;object-fit:cover" />
            <div><div style="font-weight:700;font-size:.86rem">Finest Saffron</div><div class="stars" style="font-size:.72rem">★★★★★</div><div class="muted" style="font-size:.72rem">Handpicked threads</div></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST STRIP -->
  <section class="band-brand">
    <div class="wrap" style="padding-block:18px">
      <div style="display:flex;flex-wrap:wrap;gap:10px 28px;justify-content:center;align-items:center;font-size:.82rem;font-weight:600;color:var(--brand-800);letter-spacing:.02em">
        {site.trust.map((t) => <span>✦ {t}</span>)}
      </div>
    </div>
  </section>

  <!-- CATEGORIES -->
  <section class="section">
    <div class="wrap">
      <div class="reveal" style="text-align:center;max-width:46ch;margin:0 auto 38px">
        <p class="eyebrow mb-3">View by Categories</p>
        <h2 style="font-size:clamp(2rem,6vw,2.9rem)">Curated collections of edible elegance</h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-6">
        {tiles.map((t) => (
          <a class="cat-tile reveal" href={`/products.html?cat=${t.id}`}>
            <img src={t.img} alt={t.label} />
            <div class="cat-tile-cap"><h3>{t.label}</h3><span class="more">{t.more} →</span></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURED PRODUCTS -->
  <section class="section" style="padding-top:0">
    <div class="wrap">
      <div class="reveal" style="display:flex;flex-wrap:wrap;gap:14px;align-items:end;justify-content:space-between;margin-bottom:28px">
        <div>
          <p class="eyebrow mb-2">New Additions</p>
          <h2 style="font-size:clamp(1.8rem,5.5vw,2.6rem)">Latest from the workshop</h2>
        </div>
        <a class="btn btn-outline btn-sm" href="/products.html">View All Products</a>
      </div>
      <div class="prod-grid cols-4">
        {featured.map((p) => <ProductCard item={p} />)}
      </div>
    </div>
  </section>

  <!-- SAFFRON SPOTLIGHT -->
  <section class="band-dark">
    <div class="wrap section">
      <div class="grid lg:grid-cols-2 gap-10 items-center">
        <div class="reveal" style="order:2">
          <p class="eyebrow mb-3">Saffron · Finest Quality</p>
          <h2 style="color:#fff;font-size:clamp(2rem,6vw,3rem)">A single thread of pure indulgence</h2>
          <p style="color:#cbc3b6;margin-top:1rem;max-width:48ch">
            Carefully handpicked, our saffron is known for its vibrant colour, distinct aroma and exquisite flavour.
            Sourced from reputable farms for authenticity and optimal quality — adding luxury and visual appeal to every culinary creation.
          </p>
          <div style="display:flex;gap:12px;margin-top:1.6rem;flex-wrap:wrap">
            <a class="btn btn-primary" href="/products/varnika-premium-saffron.html">Discover Saffron</a>
            <a class="btn btn-outline" href="/products.html?cat=food" style="border-color:rgba(255,255,255,.3);color:#fff">All Food Products</a>
          </div>
        </div>
        <div class="reveal" style="order:1;border-radius:22px;overflow:hidden;aspect-ratio:5/4">
          <img class="hero-img" src="/assets/images/saffron.png" alt="Premium saffron" />
        </div>
      </div>
    </div>
  </section>

  <!-- SILVER & GOLD LEAVES -->
  <section class="section">
    <div class="wrap">
      <div class="grid lg:grid-cols-2 gap-10 items-center">
        <div class="reveal" style="border-radius:22px;overflow:hidden;aspect-ratio:5/4">
          <img class="hero-img" src="/assets/images/silver-leaves.jpg" alt="Silver and gold leaves" />
        </div>
        <div class="reveal">
          <p class="eyebrow mb-3">Silver &amp; Gold Leaves</p>
          <h2 style="font-size:clamp(2rem,6vw,3rem)">Edible elegance, beaten to perfection</h2>
          <p class="muted" style="margin-top:1rem;max-width:48ch">
            Our silver and gold leaves are meticulously crafted to perfection. These edible metallic sheets are widely
            used in Indian sweets and confections, imparting elegance and opulence to the dining experience. Strict quality
            standards ensure they meet the expectations of home cooks and professional chefs alike.
          </p>
          <div style="display:flex;gap:10px;margin-top:1.6rem;flex-wrap:wrap">
            <a class="btn btn-primary" href="/products/gold-leaves-and-flakes.html">Gold Leaves</a>
            <a class="btn btn-outline" href="/products/silver-leaves-and-flakes.html">Silver Leaves</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS BAND -->
  <section class="band-deep">
    <div class="wrap" style="padding-block:54px">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div class="reveal"><div class="stat-num" style="color:var(--brand-300)">2010</div><p style="color:#d9d2c6;font-size:.86rem;margin-top:.3rem">Established</p></div>
        <div class="reveal"><div class="stat-num" style="color:var(--brand-300)" data-count="13" data-suffix="+">13+</div><p style="color:#d9d2c6;font-size:.86rem;margin-top:.3rem">Years of experience</p></div>
        <div class="reveal"><div class="stat-num" style="color:var(--brand-300)" data-count="100" data-suffix="%">100%</div><p style="color:#d9d2c6;font-size:.86rem;margin-top:.3rem">Vegetarian certified</p></div>
        <div class="reveal"><div class="stat-num" style="color:var(--brand-300)" data-count="6" data-suffix="+">6+</div><p style="color:#d9d2c6;font-size:.86rem;margin-top:.3rem">Signature products</p></div>
      </div>
    </div>
  </section>

  <!-- INSTAGRAM -->
  <section class="section">
    <div class="wrap">
      <div class="reveal" style="text-align:center;margin-bottom:26px">
        <p class="eyebrow mb-2">Find us on Instagram</p>
        <h2 style="font-size:clamp(1.8rem,5vw,2.4rem)">{site.instagram.handle}</h2>
      </div>
      <div class="ig-grid reveal">
        {ig.map((src) => (
          <a class="ig-cell" href="#"><img src={src} alt="Instagram post" loading="lazy" /></a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="padding-top:0">
    <div class="wrap">
      <div class="reveal band-brand shadow-soft" style="border-radius:24px;padding:clamp(28px,6vw,56px);text-align:center">
        <p class="eyebrow mb-3">Trade &amp; Bulk Enquiries</p>
        <h2 style="font-size:clamp(1.9rem,5.5vw,2.8rem);max-width:20ch;margin:0 auto">Bring royal craftsmanship to your shelves</h2>
        <p class="muted" style="max-width:50ch;margin:1rem auto 0">For wholesale, export and custom coating enquiries, our team is ready to help with samples and pricing.</p>
        <div style="display:flex;gap:12px;justify-content:center;margin-top:1.6rem;flex-wrap:wrap">
          <a class="btn btn-primary" href="/contact.html">Request a Quote</a>
          <a class="btn btn-outline" href={site.cta.phoneHref}>{site.cta.phone}</a>
        </div>
      </div>
    </div>
  </section>
</Base>
