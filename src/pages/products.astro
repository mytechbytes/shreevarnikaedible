---
import Base from "../layouts/Base.astro";
import ProductCard from "../components/ProductCard.astro";
import itemsData from "../data/items.json";
import site from "../data/site.json";
const items = itemsData;
const cats = site.categories; // includes "all"

// Pure-CSS category filter: the radios are common preceding siblings of BOTH
// the tab wrapper (.filter-row) and the grid (.shop-grid). Active tab targeted
// via the sibling wrapper class; cards hidden by [data-cat] mismatch.
const activeCss = cats
  .map((c) => `#cat-${c.id}:checked ~ .filter-row .shop-tabs label[for="cat-${c.id}"]{background:var(--brand-600);border-color:var(--brand-600);color:#fff;}`)
  .join("\n");
const hideCss = cats
  .filter((c) => c.id !== "all")
  .map((c) => `#cat-${c.id}:checked ~ .shop-grid .card:not([data-cat="${c.id}"]){display:none;}`)
  .join("\n");
const filterCss = activeCss + "\n" + hideCss;
---
<Base title="Products — Shree Varnika Edible Products" description="Browse edible silver & gold leaves, saffron, hing, coated spices and pooja articles." activeId="">
  <div data-shop>
    <!-- PAGE HEAD -->
    <section class="band-brand">
      <div class="wrap" style="padding-block:clamp(36px,7vw,64px)">
        <p class="eyebrow mb-2">Our Catalogue</p>
        <h1 data-shop-title style="font-size:clamp(2.2rem,7vw,3.4rem)">All Products</h1>
        <p class="muted" style="max-width:56ch;margin-top:.6rem">Hygienic, pure and 100% vegetarian — edible silver &amp; gold leaves, premium spices and pooja essentials, crafted with automated precision.</p>
      </div>
    </section>

    <!-- FILTER BAR + GRID -->
    <section class="section" style="padding-top:28px">
      <div class="wrap">
        <div class="shop-radios">
          {cats.map((c, i) => (
            <input type="radio" name="shop-cat" id={`cat-${c.id}`} value={c.id} data-cat-radio data-label={c.label} checked={i === 0} />
          ))}

          <div class="filter-row" style="display:flex;flex-wrap:wrap;gap:14px;align-items:center;justify-content:space-between;margin-bottom:22px">
            <div class="shop-tabs">
              {cats.map((c) => (
                <label class="chip" for={`cat-${c.id}`}>{c.label}</label>
              ))}
            </div>
            <div style="display:flex;align-items:center;gap:10px;margin-left:auto">
              <span class="muted" style="font-size:.84rem" data-shop-count>{items.length} products</span>
              <div class="theme-pick" style="min-width:170px">
                <select class="field" data-sort aria-label="Sort products" style="padding-right:2rem">
                  <option value="featured">Sort: Featured</option>
                  <option value="name">Name (A–Z)</option>
                  <option value="price-asc">Price (low→high)</option>
                  <option value="price-desc">Price (high→low)</option>
                </select>
              </div>
            </div>
          </div>

          <div class="prod-grid cols-4 shop-grid" data-grid>
            {items.map((p) => <ProductCard item={p} />)}
          </div>
        </div>
      </div>
    </section>
  </div>

  <style set:html={filterCss}></style>
  <script>
    import "../scripts/shop.js";
  </script>
</Base>
