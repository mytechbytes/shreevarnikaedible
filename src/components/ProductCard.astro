---
import Icon from "./Icon.astro";
interface Props { item: any; }
const { item } = Astro.props;
const stars = "★★★★★".slice(0, item.rating) + "☆☆☆☆☆".slice(0, 5 - item.rating);
const href = `/products/${item.slug}.html`;
const showOnwards = item.from.startsWith("₹");
---
<article class="card" data-cat={item.category} data-name={item.name} data-price={item.from}>
  {item.badge && <span class="badge">{item.badge}</span>}
  <a class="card-media" href={href} aria-label={item.name}>
    <img src={item.image} alt={item.name} loading="lazy" />
    <div class="card-quick">
      <button type="button" class="btn btn-dark btn-sm btn-block" data-quick={item.id}>Quick View</button>
    </div>
  </a>
  <div class="card-body">
    <span class="card-cat">{item.collection}</span>
    <a href={href}><h3 class="card-title">{item.name}</h3></a>
    <div class="stars" aria-label={`${item.rating} out of 5`}>{stars}</div>
    <div class="card-foot">
      <span class="price">{item.from}{showOnwards && <small> onwards</small>}</span>
      <a class="btn-ghost" href={href} style="font-weight:700;font-size:.84rem;display:inline-flex;gap:.3rem;align-items:center">Details <Icon name="arrow" size={15} /></a>
    </div>
  </div>
</article>
