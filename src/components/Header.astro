---
import site from "../data/site.json";
import Icon from "./Icon.astro";
interface Props { activeId?: string; }
const { activeId = "" } = Astro.props;
const { brand, nav, cta } = site;
---
<input type="checkbox" id="nav-toggle" class="nav-toggle" aria-label="Toggle menu" />

<header class="site-header" data-header>
  <div class="wrap hdr-row">
    <a class="brand" href="/" aria-label={`${brand.name} home`}>
      <img class="brand-logo" src={brand.logo} alt={`${brand.name} ${brand.suffix}`} width="58" height="44" />
      <span class="leading-none">
        <span class="brand-name">{brand.name}</span>
        <span class="brand-sub" style="display:block">{brand.suffix}</span>
      </span>
    </a>

    <nav class="nav-desk">
      {nav.map((n) => (
        <a class={`nav-link${n.id === activeId ? " active" : ""}`} href={n.href}>{n.label}</a>
      ))}
    </nav>

    <div class="hdr-actions">
      <a class="icon-btn" href="/cart.html" aria-label="Enquiry list">
        <Icon name="bag" size={20} />
        <span class="cart-count" data-cart-count style="display:none">0</span>
      </a>
      <label class="icon-btn burger" for="nav-toggle" aria-label="Open menu">
        <Icon name="menu" size={22} />
      </label>
    </div>
  </div>
</header>

<div class="drawer">
  <label class="drawer-bg" for="nav-toggle" aria-label="Close menu"></label>
  <aside class="drawer-panel">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.6rem">
      <span class="serif" style="font-size:1.2rem">Menu</span>
      <label class="icon-btn" for="nav-toggle" aria-label="Close menu"><Icon name="close" size={22} /></label>
    </div>
    {nav.map((n) => (
      <a class="drawer-link" href={n.href}>{n.label} <Icon name="arrow" size={15} /></a>
    ))}
    <a class="btn btn-primary btn-block" href={cta.href} style="margin-top:auto">{cta.label}</a>
  </aside>
</div>
